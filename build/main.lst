 133:Source/solver.h **** 
 134:Source/solver.h **** // ŌöĆŌöĆŌöĆ Cold-component decomposition ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 135:Source/solver.h **** //
 136:Source/solver.h **** // Mirrors Components.collectCold() in ai.lua exactly, including traversal
 137:Source/solver.h **** // order (boxes ascending; each box's 4 edges in stored top,right,bottom,left
 138:Source/solver.h **** // order; depth-first recursion into the first qualifying 2-filled neighbour).
 139:Source/solver.h **** // That order determines comp.edge / entryEdges, so it must not drift.
 140:Source/solver.h **** //
 141:Source/solver.h **** // Topology (1-based ids, matching board.lua):
 142:Source/solver.h **** //   numBoxes, numEdges
 143:Source/solver.h **** //   boxEdges : numBoxes*4   edge id per (box,slot), slots 0..3
 144:Source/solver.h **** //   edgeBoxes: numEdges*2   box ids adjacent to an edge (0 = none)
 145:Source/solver.h **** // Per-call:
 146:Source/solver.h **** //   filled   : numEdges     1 if that edge id is filled
 147:Source/solver.h **** //   excluded : numBoxes     1 if that box id is pre-seeded as seen (hot)
 148:Source/solver.h **** //
 149:Source/solver.h **** // Output: comps[] each with len, isLoop, edge, nEntries, entry[].
 150:Source/solver.h **** 
 151:Source/solver.h **** #define DOTSAI_MAX_BOXES 49     // (8-1)^2
 152:Source/solver.h **** #define DOTSAI_MAX_EDGES 112    // 8*7*2
 153:Source/solver.h **** 
 154:Source/solver.h **** typedef struct {
 155:Source/solver.h ****     int     len;
 156:Source/solver.h ****     int     isLoop;             // 1 = no entry edges
 157:Source/solver.h ****     int     edge;               // entry[0] for chains, firstEdge for loops
 158:Source/solver.h ****     int     nEntries;
 159:Source/solver.h ****     uint8_t entry[DOTSAI_MAX_EDGES];
 160:Source/solver.h **** } ColdComp;
 161:Source/solver.h **** 
 162:Source/solver.h **** typedef struct {
 163:Source/solver.h ****     int        numBoxes;
 164:Source/solver.h ****     int        numEdges;
 165:Source/solver.h ****     uint8_t    boxEdges[DOTSAI_MAX_BOXES + 1][4];   // 1-based box ids
 166:Source/solver.h ****     uint8_t    edgeBoxes[DOTSAI_MAX_EDGES + 1][2];  // 1-based edge ids; 0=none
 167:Source/solver.h ****     // per-call scratch
 168:Source/solver.h ****     const uint8_t* filled;
 169:Source/solver.h ****     uint8_t        seen[DOTSAI_MAX_BOXES + 1];
 170:Source/solver.h **** } ColdTopo;
ARM GAS  /var/folders/f4/l09z6jwn7f19llqrrwpfcg0w0000gp/T//ccuwsxQL.s 			page 34


 171:Source/solver.h **** 
 172:Source/solver.h **** static int cold_fillcount(const ColdTopo* t, int box) {
 173:Source/solver.h ****     int n = 0;
 174:Source/solver.h ****     for (int k = 0; k < 4; k++) {
 175:Source/solver.h ****         int e = t->boxEdges[box][k];
 176:Source/solver.h ****         if (e && t->filled[e]) n++;
 177:Source/solver.h ****     }
 178:Source/solver.h ****     return n;
 179:Source/solver.h **** }
 180:Source/solver.h **** 
