  27:Source/main.c **** // ŌöĆŌöĆŌöĆ solve bindings ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
  28:Source/main.c **** 
  29:Source/main.c **** static int lua_solve_reset(lua_State* L) {
  30:Source/main.c ****     (void)L;
  31:Source/main.c ****     solver_reset();
  32:Source/main.c ****     return 0;
  33:Source/main.c **** }
  34:Source/main.c **** 
  35:Source/main.c **** static int lua_solve(lua_State* L) {
  36:Source/main.c ****     (void)L;
  37:Source/main.c ****     size_t chainsLen = 0, loopsLen = 0;
  38:Source/main.c ****     const char* chains = pd->lua->getArgBytes(1, &chainsLen);
  39:Source/main.c ****     const char* loops  = pd->lua->getArgBytes(2, &loopsLen);
  40:Source/main.c **** 
  41:Source/main.c ****     CompState state;
  42:Source/main.c ****     memset(&state, 0, sizeof(state));
  43:Source/main.c **** 
  44:Source/main.c ****     if (chains) {
  45:Source/main.c ****         for (size_t i = 0; i < chainsLen; i++) {
  46:Source/main.c ****             uint8_t len = (uint8_t)chains[i];
  47:Source/main.c ****             if (len > DOTSAI_MAX_LEN) len = DOTSAI_MAX_LEN;
  48:Source/main.c ****             if (len > 0) state.chains[len]++;
  49:Source/main.c ****         }
  50:Source/main.c ****     }
  51:Source/main.c ****     if (loops) {
  52:Source/main.c ****         for (size_t i = 0; i < loopsLen; i++) {
  53:Source/main.c ****             uint8_t len = (uint8_t)loops[i];
  54:Source/main.c ****             if (len > DOTSAI_MAX_LEN) len = DOTSAI_MAX_LEN;
  55:Source/main.c ****             if (len > 0) state.loops[len]++;
  56:Source/main.c ****         }
  57:Source/main.c ****     }
  58:Source/main.c **** 
  59:Source/main.c ****     pd->lua->pushInt(solve(&state));
  60:Source/main.c ****     return 1;
  61:Source/main.c **** }
