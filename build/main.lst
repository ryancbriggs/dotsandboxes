   1:Source/solver.h **** //
   2:Source/solver.h **** // solver.h ŌĆö Pure C dots-and-boxes kernels, free of any Playdate API.
   3:Source/solver.h **** //
   4:Source/solver.h **** // Two algorithms, each a faithful port of the audited Lua reference in
   5:Source/solver.h **** // Source/ai.lua:
   6:Source/solver.h **** //
   7:Source/solver.h **** //   solve()           ŌåÉŌåÆ solveComponents() + componentOpenValue()
   8:Source/solver.h **** //   cold_decompose()  ŌåÉŌåÆ Components.collectCold()
   9:Source/solver.h **** //
  10:Source/solver.h **** // "Pure" means: no pd_api.h, no globals beyond the solve memo, deterministic.
  11:Source/solver.h **** // This header is #included by Source/main.c (the Playdate extension) and by
  12:Source/solver.h **** // tests/parity_test.c (the build-time differential check). Keeping the logic
  13:Source/solver.h **** // here ŌĆö and the Lua reference short and readable ŌĆö is what makes the C
  14:Source/solver.h **** // auditable: the test fuzzes this against an independent reference and the
  15:Source/solver.h **** // build fails on any divergence.
  16:Source/solver.h **** //
  17:Source/solver.h **** // IMPORTANT: any change to the arithmetic/traversal here MUST be mirrored in
  18:Source/solver.h **** // the Lua reference (ai.lua) and vice-versa. The parity test enforces it.
  19:Source/solver.h **** //
