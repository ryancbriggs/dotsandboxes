   1:Source/main.c **** //
   2:Source/main.c **** // main.c ŌĆō Playdate C extension: thin Lua bindings over Source/solver.h.
   3:Source/main.c **** //
   4:Source/main.c **** // Lua surface:
   5:Source/main.c **** //   dotsai.solve_reset()            clear the endgame memo (once per AI move)
   6:Source/main.c **** //   dotsai.solve(chains, loops)     endgame value (byte-string component lens)
   7:Source/main.c **** //   dotsai.cold_init(dots, be, eb)  send static board topology once per game
   8:Source/main.c **** //   dotsai.cold(filled, excluded)   cold-component decomposition for a position
   9:Source/main.c **** //
  10:Source/main.c **** // All algorithmic logic lives in solver.h (pure C, no Playdate deps) so the
  11:Source/main.c **** // exact same code is exercised by the build-time parity test. This file only
  12:Source/main.c **** // marshals data across the Lua/C boundary.
  13:Source/main.c **** //
  14:Source/main.c **** 
  15:Source/main.c **** #include <stdint.h>
  16:Source/main.c **** #include <string.h>
  17:Source/main.c **** 
  18:Source/main.c **** #include "pd_api.h"
  19:Source/main.c **** #include "solver.h"
  20:Source/main.c **** 
  21:Source/main.c **** static PlaydateAPI* pd = NULL;
  22:Source/main.c **** 
  23:Source/main.c **** // Resident board topology, set by dotsai.cold_init at game start.
  24:Source/main.c **** static ColdTopo s_topo;
  25:Source/main.c **** static int      s_topo_ready = 0;
