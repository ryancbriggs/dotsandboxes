  47:Source/solver.h **** static uint32_t hash_state(const CompState* s) {
  48:Source/solver.h ****     uint32_t h = 2166136261u;                 // FNV-1a
  49:Source/solver.h ****     const uint8_t* p = (const uint8_t*)s;
  50:Source/solver.h ****     for (unsigned i = 0; i < sizeof(*s); i++) { h ^= p[i]; h *= 16777619u; }
  51:Source/solver.h ****     return h;
  52:Source/solver.h **** }
  53:Source/solver.h **** 
  54:Source/solver.h **** static int memo_lookup(const CompState* s, int* out) {
  55:Source/solver.h ****     const uint32_t mask = DOTSAI_MEMO_SIZE - 1;
  56:Source/solver.h ****     const uint32_t base = hash_state(s) & mask;
  57:Source/solver.h ****     for (uint32_t probe = 0; probe < DOTSAI_MEMO_SIZE; probe++) {
  58:Source/solver.h ****         uint32_t idx = (base + probe) & mask;
  59:Source/solver.h ****         if (!s_memo[idx].occupied) return 0;
  60:Source/solver.h ****         if (memcmp(&s_memo[idx].key, s, sizeof(CompState)) == 0) {
  61:Source/solver.h ****             *out = s_memo[idx].value;
  62:Source/solver.h ****             return 1;
  63:Source/solver.h ****         }
  64:Source/solver.h ****     }
  65:Source/solver.h ****     return 0;
  66:Source/solver.h **** }
