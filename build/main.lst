   1:Source/main.c **** //
   2:Source/main.c **** // main.c â€“ Playdate C extension for the dots-and-boxes endgame solver.
   3:Source/main.c **** //
   4:Source/main.c **** // Exposes two Lua functions:
   5:Source/main.c **** //   dotsai.solve_reset()           clear the memo (call at start of each AI move)
   6:Source/main.c **** //   dotsai.solve(chains, loops)    compute the endgame value
   7:Source/main.c **** //
   8:Source/main.c **** // `chains` and `loops` are byte strings where each byte is one component's
   9:Source/main.c **** // length in boxes. Returns an integer score from the moving player's
  10:Source/main.c **** // perspective (positive = good for the mover).
  11:Source/main.c **** //
  12:Source/main.c **** // This is a port of evaluateTerminal's solveComponents call. The recursion
  13:Source/main.c **** // structure mirrors the Lua version. The memo is a fixed-size linear-probe
  14:Source/main.c **** // hash table keyed on a packed component-count struct.
  15:Source/main.c **** //
  16:Source/main.c **** 
  17:Source/main.c **** #include <stdint.h>
  18:Source/main.c **** #include <string.h>
  19:Source/main.c **** 
  20:Source/main.c **** #include "pd_api.h"
  21:Source/main.c **** 
  22:Source/main.c **** static PlaydateAPI* pd = NULL;
  23:Source/main.c **** 
  24:Source/main.c **** // â”€â”€â”€ Endgame solver internals â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
  25:Source/main.c **** 
ARM GAS  /var/folders/f4/l09z6jwn7f19llqrrwpfcg0w0000gp/T//ccu683hx.s 			page 3


  26:Source/main.c **** // Max component length we handle. On an 8x8 board the upper bound is 49
  27:Source/main.c **** // (all boxes in one component), but realistic positions stay well under
  28:Source/main.c **** // 32. Anything longer gets clamped on input.
  29:Source/main.c **** #define MAX_LEN    50
  30:Source/main.c **** 
  31:Source/main.c **** // Power-of-two so we can mask instead of mod. 4096 entries Ã— ~108 bytes
  32:Source/main.c **** // each â‰ˆ 442 KB. Resets to all-zero between AI moves.
  33:Source/main.c **** #define MEMO_SIZE  4096
  34:Source/main.c **** 
  35:Source/main.c **** typedef struct {
  36:Source/main.c ****     uint8_t chains[MAX_LEN + 1];  // count of chains with each length (idx 0 unused)
  37:Source/main.c ****     uint8_t loops [MAX_LEN + 1];
  38:Source/main.c **** } CompState;
  39:Source/main.c **** 
  40:Source/main.c **** typedef struct {
  41:Source/main.c ****     CompState key;
  42:Source/main.c ****     int16_t   value;
  43:Source/main.c ****     uint8_t   occupied;
  44:Source/main.c **** } MemoEntry;
  45:Source/main.c **** 
  46:Source/main.c **** static MemoEntry s_memo[MEMO_SIZE];
  47:Source/main.c **** 
  48:Source/main.c **** static uint32_t hash_state(const CompState* s) {
  49:Source/main.c ****     // FNV-1a over the raw bytes.
  50:Source/main.c ****     uint32_t h = 2166136261u;
  51:Source/main.c ****     const uint8_t* p = (const uint8_t*)s;
  52:Source/main.c ****     for (unsigned i = 0; i < sizeof(*s); i++) {
  53:Source/main.c ****         h ^= p[i];
  54:Source/main.c ****         h *= 16777619u;
  55:Source/main.c ****     }
  56:Source/main.c ****     return h;
  57:Source/main.c **** }
  58:Source/main.c **** 
  59:Source/main.c **** static int memo_lookup(const CompState* s, int* out) {
  60:Source/main.c ****     const uint32_t mask = MEMO_SIZE - 1;
  61:Source/main.c ****     const uint32_t base = hash_state(s) & mask;
  62:Source/main.c ****     for (uint32_t probe = 0; probe < MEMO_SIZE; probe++) {
  63:Source/main.c ****         uint32_t idx = (base + probe) & mask;
  64:Source/main.c ****         if (!s_memo[idx].occupied) return 0;
  65:Source/main.c ****         if (memcmp(&s_memo[idx].key, s, sizeof(CompState)) == 0) {
  66:Source/main.c ****             *out = s_memo[idx].value;
  67:Source/main.c ****             return 1;
  68:Source/main.c ****         }
  69:Source/main.c ****     }
  70:Source/main.c ****     return 0;
  71:Source/main.c **** }
  72:Source/main.c **** 
  73:Source/main.c **** static void memo_store(const CompState* s, int v) {
  74:Source/main.c ****     const uint32_t mask = MEMO_SIZE - 1;
  75:Source/main.c ****     const uint32_t base = hash_state(s) & mask;
  76:Source/main.c ****     for (uint32_t probe = 0; probe < MEMO_SIZE; probe++) {
  77:Source/main.c ****         uint32_t idx = (base + probe) & mask;
  78:Source/main.c ****         if (!s_memo[idx].occupied) {
  79:Source/main.c ****             s_memo[idx].key = *s;
  80:Source/main.c ****             s_memo[idx].value = (int16_t)v;
  81:Source/main.c ****             s_memo[idx].occupied = 1;
  82:Source/main.c ****             return;
ARM GAS  /var/folders/f4/l09z6jwn7f19llqrrwpfcg0w0000gp/T//ccu683hx.s 			page 4


  83:Source/main.c ****         }
  84:Source/main.c ****         if (memcmp(&s_memo[idx].key, s, sizeof(CompState)) == 0) {
  85:Source/main.c ****             s_memo[idx].value = (int16_t)v;
  86:Source/main.c ****             return;
  87:Source/main.c ****         }
  88:Source/main.c ****     }
  89:Source/main.c ****     // Table full; drop silently (very rare; cleared next solve_reset).
  90:Source/main.c **** }
  91:Source/main.c **** 
  92:Source/main.c **** static int solve(CompState* s) {
  93:Source/main.c ****     int cached;
  94:Source/main.c ****     if (memo_lookup(s, &cached)) return cached;
  95:Source/main.c **** 
  96:Source/main.c ****     // Terminal: no components left.
  97:Source/main.c ****     int any = 0;
  98:Source/main.c ****     for (int i = 0; i <= MAX_LEN; i++) {
  99:Source/main.c ****         if (s->chains[i] || s->loops[i]) { any = 1; break; }
 100:Source/main.c ****     }
 101:Source/main.c ****     if (!any) {
 102:Source/main.c ****         memo_store(s, 0);
 103:Source/main.c ****         return 0;
 104:Source/main.c ****     }
 105:Source/main.c **** 
 106:Source/main.c ****     int best = -32768;
 107:Source/main.c **** 
 108:Source/main.c ****     // Try removing one chain of each length present. DX is geometrically
 109:Source/main.c ****     // possible for any chain of length >= 2 (opp takes L-2, mover gets the
 110:Source/main.c ****     // 2-domino). The L=2/3 cases matter on small boards where short chains
 111:Source/main.c ****     // are common.
 112:Source/main.c ****     for (int len = 1; len <= MAX_LEN; len++) {
 113:Source/main.c ****         uint8_t prev = s->chains[len];
 114:Source/main.c ****         if (prev == 0) continue;
 115:Source/main.c ****         s->chains[len] = prev - 1;
 116:Source/main.c ****         int nextVal = solve(s);
 117:Source/main.c ****         s->chains[len] = prev;
 118:Source/main.c **** 
 119:Source/main.c ****         int worst = -len - nextVal;
 120:Source/main.c ****         if (len >= 2) {
 121:Source/main.c ****             int keep = -(len - 4) + nextVal;
 122:Source/main.c ****             if (keep < worst) worst = keep;
 123:Source/main.c ****         }
 124:Source/main.c ****         if (worst > best) best = worst;
 125:Source/main.c ****     }
 126:Source/main.c **** 
 127:Source/main.c ****     // Try removing one loop of each length present. Loop DX gives back a
 128:Source/main.c ****     // 4-domino (opp takes L-4, mover gets 4), so requires L >= 4.
 129:Source/main.c ****     for (int len = 1; len <= MAX_LEN; len++) {
 130:Source/main.c ****         uint8_t prev = s->loops[len];
 131:Source/main.c ****         if (prev == 0) continue;
 132:Source/main.c ****         s->loops[len] = prev - 1;
 133:Source/main.c ****         int nextVal = solve(s);
 134:Source/main.c ****         s->loops[len] = prev;
 135:Source/main.c **** 
 136:Source/main.c ****         int worst = -len - nextVal;
 137:Source/main.c ****         if (len >= 4) {
 138:Source/main.c ****             int keep = -(len - 8) + nextVal;
 139:Source/main.c ****             if (keep < worst) worst = keep;
ARM GAS  /var/folders/f4/l09z6jwn7f19llqrrwpfcg0w0000gp/T//ccu683hx.s 			page 5


 140:Source/main.c ****         }
 141:Source/main.c ****         if (worst > best) best = worst;
 142:Source/main.c ****     }
 143:Source/main.c **** 
 144:Source/main.c ****     if (best == -32768) best = 0;
 145:Source/main.c ****     memo_store(s, best);
 146:Source/main.c ****     return best;
 147:Source/main.c **** }
 148:Source/main.c **** 
